<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- WebView to render the Next.js Dashboard -->
    <android.webkit.WebView
        android:id="@+id/dashboard_webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Configuration Layout Container -->
    <LinearLayout
        android:id="@+id/settings_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FAFAF8">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FinTrack AI Client"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/permission_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checking Permissions..."
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Webhook URL"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:layout_marginTop="30dp"/>

        <EditText
            android:id="@+id/webhook_url_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:hint="http://192.168.1.15:8080/api/v1/webhook/sms"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Key / Device Key"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#6B7280"
            android:layout_marginTop="15dp"/>

        <EditText
            android:id="@+id/api_key_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:hint="Enter SHA API Key"
            android:textSize="14sp" />

        <Button
            android:id="@+id/save_settings_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:backgroundTint="#111827"
            android:textColor="#FFFFFF"
            android:layout_marginTop="30dp"/>

        <Button
            android:id="@+id/open_webview_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Dashboard UI"
            android:backgroundTint="#C9A76A"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Floating Gear Button to toggle settings panel when inside Webview -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/settings_fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_preferences"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:visibility="gone"
        app:backgroundTint="#111827"
        app:tint="#FFFFFF"/>

</androidx.constraintlayout.widget.ConstraintLayout>
